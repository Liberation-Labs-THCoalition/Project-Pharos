# Rivet Coding/Admin Agent — Configuration
# Copy to .env before running: cp config.env .env

# ── LLM Inference (runs on separate Hetzner box) ─────────────
LLM_URL=http://46.224.162.211:8080
LLM_MODEL=ornith:9b

# ── Agent Identity ───────────────────────────────────────────
AGENT_NAME=Rivet

# ── OGPSA Persona Protection ────────────────────────────────
OGPSA_ENABLED=true

# ── Kintsugi Self-Scaffolding ────────────────────────────────
KINTSUGI_SCAFFOLD=true

# ── Database (Mnemosyne persistence) ────────────────────────
POSTGRES_USER=rivet
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rivet

# ── HippoRAG Knowledge Graph ────────────────────────────────
HIPPORAG_PORT=11236
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Pharos Knowledge Packs ───────────────────────────────────
PHAROS_PACKS_DIR=/app/packs

# ── Mnemosyne Modules ───────────────────────────────────────
MNEMOSYNE_SIRA_ENABLED=true
MNEMOSYNE_ENRICHMENT_ENABLED=true
CONSOLIDATION_INTERVAL=6

# ── Garuda (Poison Tasting) ─────────────────────────────────
GARUDA_ENABLED=true

# ── Code Execution ──────────────────────────────────────────
CODE_EXECUTION_ENABLED=true
SANDBOX_MODE=docker

# ── Network / Ports ─────────────────────────────────────────
GATEWAY_PORT=8092
CORS_ORIGINS=*
LOG_LEVEL=info
