# Kintsugi Mutual Aid Agent — Configuration
# Copy to .env before running: cp config.env .env

# ── LLM Inference (runs on separate Hetzner box) ─────────────
LLM_URL=http://46.224.162.211:8080
LLM_MODEL=ll-custom-slerp

# ── Agent Identity ───────────────────────────────────────────
AGENT_NAME=Kintsugi
PERSONA_FILE=/app/persona/megs_persona.md

# ── OGPSA Persona Protection ────────────────────────────────
# Prevents persona drift via gradient survival gate
OGPSA_ENABLED=true

# ── Ornith Self-Scaffolding ──────────────────────────────────
ORNITH_SCAFFOLD=true

# ── Database (Mnemosyne persistence) ────────────────────────
POSTGRES_USER=kintsugi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kintsugi

# ── HippoRAG Knowledge Graph ────────────────────────────────
HIPPORAG_PORT=11235
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Pharos Knowledge Packs ───────────────────────────────────
# Packs are mounted read-only from ./packs/
PHAROS_PACKS_DIR=/app/packs

# ── Mnemosyne Modules ───────────────────────────────────────
MNEMOSYNE_SIRA_ENABLED=true
MNEMOSYNE_ENRICHMENT_ENABLED=true
CONSOLIDATION_INTERVAL=6

# ── Garuda (Poison Tasting) ─────────────────────────────────
GARUDA_ENABLED=true

# ── Network / Ports ─────────────────────────────────────────
GATEWAY_PORT=8090
CORS_ORIGINS=*
LOG_LEVEL=info
